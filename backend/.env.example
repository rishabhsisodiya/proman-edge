# Toggle mock data (true = mock, false = real ERPNext)
USE_MOCK=true

# MariaDB — ERPNext database (local or Frappe Cloud)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=_800ba922c4374766
DB_USER=root
DB_PASS=
# DB_SSL_CA=/path/to/chain.pem   # required for Frappe Cloud TLS

# ERPNext sites — add API key/secret when test access is granted
ERPNEXT_PISPL_URL=https://pispl.frappe.cloud
ERPNEXT_PISPL_API_KEY=
ERPNEXT_PISPL_API_SECRET=

ERPNEXT_ACE_URL=https://ace.frappe.cloud
ERPNEXT_ACE_API_KEY=
ERPNEXT_ACE_API_SECRET=

# Redis (optional in dev — caching disabled if not set)
REDIS_URL=redis://localhost:6379

# Server
PORT=4000
FRONTEND_URL=http://localhost:3000

# JWT — change this to a long random string in production
JWT_SECRET=proman-edge-dev-secret
